<?xml version="1.0"?>
<!--
  Sub-task 7: RETURN THROUGH THE SAME (OUTBOUND) GATE
  ===================================================
  Three-leg /next_goal stream: pre-gate -> through-gate -> pickup.
  EGO avoids whatever is in the depth cloud along the way.

  Sim:
    roslaunch ee478_bringup s7_return_gate.launch platform:=sim \
        gate_y:=1.8 pickup_x:=0.0 pickup_y:=0.0
  Real (operator arms, conservative velocity, short legs):
    roslaunch ee478_bringup s7_return_gate.launch platform:=real \
        gate_x:=2.0 gate_y:=0.0 pickup_x:=0.0 pickup_y:=0.0 \
        max_vel:=0.4
-->
<launch>
  <arg name="platform"   default="sim"/>
  <arg name="vio_source" default="gt"/>
  <arg name="hover_z"
       default="$(eval 0.5 if arg('platform') == 'real' else 0.7)"/>
  <arg name="gate_x"     default="3.0"/>
  <arg name="gate_y"     default="1.8"/>
  <arg name="pickup_x"   default="0.0"/>
  <arg name="pickup_y"   default="0.0"/>
  <arg name="max_vel"
       default="$(eval 0.4 if arg('platform') == 'real' else 1.0)"/>
  <arg name="fcu_url"
       default="serial:///dev/ttyTHS1:921600"/>

  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="platform"   value="$(arg platform)"/>
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="hover_z"    value="$(arg hover_z)"/>
    <arg name="fcu_url"    value="$(arg fcu_url)"/>
  </include>

  <arg name="cloud_topic"
       default="$(eval '/iris_depth_camera_vio/camera/depth/points'
                       if arg('platform') == 'sim'
                       else '/camera/depth/color/points')"/>
  <include file="$(find ee478_planner)/launch/ego_planner.launch">
    <arg name="cloud_topic"      value="$(arg cloud_topic)"/>
    <arg name="planning_horizon" value="3.0"/>
    <arg name="max_vel"          value="$(arg max_vel)"/>
  </include>

  <node pkg="rostopic" type="rostopic"
        name="return_leg1_pre_gate"
        args="pub -l -r 1.0 /next_goal geometry_msgs/PoseStamped
              '{header: {frame_id: map},
                pose: {position: {x: $(eval gate_x + 1.0),
                                  y: $(arg gate_y),
                                  z: $(arg hover_z)},
                       orientation: {w: 1.0}}}'"
        launch-prefix="bash -c 'sleep 25; timeout 12 $0 $@'"/>

  <node pkg="rostopic" type="rostopic"
        name="return_leg2_through_gate"
        args="pub -l -r 1.0 /next_goal geometry_msgs/PoseStamped
              '{header: {frame_id: map},
                pose: {position: {x: $(eval gate_x - 1.0),
                                  y: $(arg gate_y),
                                  z: $(arg hover_z)},
                       orientation: {w: 1.0}}}'"
        launch-prefix="bash -c 'sleep 37; timeout 12 $0 $@'"/>

  <node pkg="rostopic" type="rostopic"
        name="return_leg3_pickup"
        args="pub -l -r 1.0 /next_goal geometry_msgs/PoseStamped
              '{header: {frame_id: map},
                pose: {position: {x: $(arg pickup_x),
                                  y: $(arg pickup_y),
                                  z: $(arg hover_z)},
                       orientation: {w: 1.0}}}'"
        launch-prefix="bash -c 'sleep 49; $0 $@'"/>
</launch>
