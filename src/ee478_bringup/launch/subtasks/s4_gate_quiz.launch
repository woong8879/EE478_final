<?xml version="1.0"?>
<!--
  Sub-task 4G: GATE QUIZ (first gate pair) — quiz-selected gate + verified pass
  =============================================================================
  Exact copy of s4_nav_course's planner stack (s1 takeoff + EGO + waypoint_loop)
  with the course handed over to gate_quiz_node after wp0.

  NEW NUMBERING:
    wp0 (1.5, 0)   approach the monitor between the first gate pair; HOVER.
                   gate_quiz_node photographs /camera/infra1 and asks ChatGPT
                   (gpt-4o-mini vision): solve the monitor problem - LEFT or
                   RIGHT? Hover holds while waiting (no goal published).
    wp1 (3.5,+-1)  the ANSWERED gate centre:
                     LEFT  = (3.5,  1), top-corner tags 281(left) 282(right)
                     RIGHT = (3.5, -1), top-corner tags 283(left) 284(right)
                   NOT waypoint-only: /apriltag/detections refines the goal to
                   the live midpoint of the two gate tags (drift-proof) and
                   warns if the WRONG pair is ahead.
    wp2 (6.5, 0)
    wp3 (9.9, 0)   TERMINUS - hover here.

  Needs OPENAI_API_KEY in the environment (or api_key:=sk-...). Without an
  answer the drone simply keeps hovering at wp0 - fail-safe.

    export OPENAI_API_KEY=sk-...
    roslaunch ee478_bringup s4_gate_quiz.launch
-->
<launch>
  <arg name="platform"   default="real"/>
  <arg name="vio_source" default="gt"/>
  <arg name="hover_z" default="0.7"/>
  <!-- waypoint_loop drives ONLY wp0 (the quiz point); gate_quiz_node feeds
       /next_goal for everything after. -->
  <arg name="waypoints" default="1.5,0"/>
  <arg name="loop"      default="false"/>
  <arg name="max_vel"
       default="$(eval 0.3 if arg('platform') == 'real' else 1.0)"/>
  <arg name="fcu_url"
       default="serial:///dev/ttyTHS0:921600"/>
  <!-- OpenAI key for the vision quiz (falls back to $OPENAI_API_KEY). -->
  <arg name="api_key"   default="$(optenv OPENAI_API_KEY)"/>

  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="platform"   value="$(arg platform)"/>
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="hover_z"    value="$(arg hover_z)"/>
    <arg name="fcu_url"    value="$(arg fcu_url)"/>
  </include>

  <!-- EGO local planner: IDENTICAL to s4_nav_course. -->
  <arg name="cloud_topic"
       default="$(eval '/iris_depth_camera_vio/camera/depth/points'
                       if arg('platform') == 'sim'
                       else '/camera/depth/points')"/>
  <arg name="z_band" default="0.2"/>
  <arg name="max_acc" default="0.3"/>
  <arg name="max_jer" default="2.0"/>
  <include file="$(find ee478_planner)/launch/ego_planner.launch">
    <arg name="platform"         value="$(arg platform)"/>
    <arg name="cloud_topic"      value="$(arg cloud_topic)"/>
    <arg name="planning_horizon" value="3.0"/>
    <arg name="max_vel"          value="$(arg max_vel)"/>
    <arg name="max_acc"          value="$(arg max_acc)"/>
    <arg name="max_jer"          value="$(arg max_jer)"/>
    <arg name="hover_z"          value="$(arg hover_z)"/>
    <arg name="virtual_ceil"     value="$(eval arg('hover_z') + arg('z_band'))"/>
    <arg name="virtual_ground"   value="-1.0"/>
  </include>

  <!-- Waypoint sequencer: drives wp0 only (then parks; offboard watchdog
       hovers there while the quiz runs). -->
  <node pkg="ee478_planner" type="waypoint_loop_node.py"
        name="waypoint_loop" output="screen" launch-prefix="taskset -c 2-5">
    <param name="waypoints"     value="$(arg waypoints)"/>
    <param name="z"             value="$(arg hover_z)"/>
    <param name="loop"          value="$(arg loop)"/>
    <param name="start_delay_s" value="14.0"/>
  </node>

  <!-- Quiz -> gate selection -> tag-verified passage -> rest of the course. -->
  <node pkg="ee478_agent" type="gate_quiz_node.py" name="gate_quiz"
        output="screen" launch-prefix="taskset -c 2-5">
    <param name="api_key" value="$(arg api_key)"/>
    <param name="hover_z" value="$(arg hover_z)"/>
    <rosparam>
      quiz_point: [1.5, 0.0]
      left_gate:  [3.5, 1.0]
      right_gate: [3.5, -1.0]
      left_tags:  [281, 282]
      right_tags: [283, 284]
      post_waypoints: [[6.5, 0.0], [9.9, 0.0]]
      arrive_radius_m: 0.5
      pass_margin_m: 0.8
    </rosparam>
  </node>
</launch>
