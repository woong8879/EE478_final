<?xml version="1.0"?>
<!--
  Sub-task 4: OBSTACLE-AWARE NAVIGATION (waypoint course / lap)
  ============================================================
  Drone takes off, EGO-Planner is brought up, and waypoint_loop feeds a
  SEQUENCE of /next_goal points one at a time (advancing on /goal_reached
  from ego_bridge), so EGO plans around whatever is in the depth map along
  the whole course. With loop:=true the drone keeps circling -> "fly one
  lap of the map".

  Waypoints are in the map frame = SVO origin = where the stack started
  (x = initial-forward, y = initial-left, z = hover_z up). START THE STACK
  AT THE TAKEOFF SPOT so the waypoints are relative to takeoff.

  TWO MODES via the `loop` arg:
    * loop:=false -> stop at the LAST waypoint = ONE-WAY navigate-to-target
                     (mission step 3: fly the obstacle course to the store).
    * loop:=true  -> wrap forever = LAP test (circle the map to shake out
                     VIO drift / obstacle avoidance).

  SAFETY: first real run -> SMALL square/leg + slow. Enlarge once confident.

  One-way to a target (mission step 3):
    roslaunch ee478_bringup s4_nav_course.launch \
        waypoints:="2,0; 4,0" loop:=false max_vel:=0.4
  Lap test (conservative 1.5 m square, keep circling):
    roslaunch ee478_bringup s4_nav_course.launch \
        waypoints:="1.5,0; 1.5,1.5; 0,1.5; 0,0" loop:=true max_vel:=0.4
  Sim:
    roslaunch ee478_bringup s4_nav_course.launch platform:=sim \
        waypoints:="5,0; 5,5; 0,5; 0,0" loop:=true

  Flow: launch -> SVO tracking -> operator flips OFFBOARD (auto-arm +
  ascend) -> after the takeoff settle the course starts -> drone visits
  each waypoint, looping until you switch out of OFFBOARD / land (s8).
-->
<launch>
  <arg name="platform"   default="real"/>
  <arg name="vio_source" default="gt"/>
  <arg name="hover_z" default="0.7"/>
  <!-- "x1,y1; x2,y2; ..." in the map frame (= FLU: +x forward, +y LEFT,
       relative to the takeoff spot). Course = the marked lap, then HOVER at the
       last wp (loop:=false). z is hover_z (0.7) for every wp. -->
  <arg name="waypoints"
       default="1.5,0; 3.5,1; 6.5,0; 9.9,0; 9.9,1.5; 8.9,3.5; 9.9,6.5; 9.9,7.2; 5.5,7.2; 3.5,6.2; 1,7.2; 0.25,8.95"/>
  <arg name="loop"      default="false"/>
  <arg name="max_vel"
       default="$(eval 0.3 if arg('platform') == 'real' else 1.0)"/>
  <arg name="fcu_url"
       default="serial:///dev/ttyTHS0:921600"/>

  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="platform"   value="$(arg platform)"/>
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="hover_z"    value="$(arg hover_z)"/>
    <arg name="fcu_url"    value="$(arg fcu_url)"/>
  </include>

  <!-- EGO local planner. sim = gazebo iris depth; real = D435i depth
       (platform=real wires the real depth image + intrinsics). cloud_topic
       is unused in pose_type=1 but kept for completeness. -->
  <arg name="cloud_topic"
       default="$(eval '/iris_depth_camera_vio/camera/depth/points'
                       if arg('platform') == 'sim'
                       else '/camera/depth/points')"/>
  <!-- Tight CEILING (hover_z + z_band) forces EGO to avoid floor-standing
       obstacles HORIZONTALLY (can't climb over -> goes around/through the gap).
       The ground stays LOW (-1.0) so the start cell (z~=0 on the ground, plus
       any in-flight dip) is ALWAYS inside the map; a high virtual_ground put
       the ground-level drone "in obstacle" and A* failed. -->
  <arg name="z_band" default="0.2"/>
  <!-- GENTLE motion so the camera doesn't shake the VIO into divergence. The
       EGO defaults (acc 2.0, jer 10.0) make sharp, jerky moves even at low
       max_vel -> VIO loses features. SLOW but PLANNABLE: vel 0.15 sets the
       (slow) pace; acc/jer only set smoothness, and too low (0.1/0.5) starves
       the optimizer so it produces degenerate/weird trajectories. 0.3/2.0 =
       gentle yet feasible so EGO plans clean, smooth paths. -->
  <arg name="max_acc" default="0.3"/>
  <arg name="max_jer" default="2.0"/>
  <include file="$(find ee478_planner)/launch/ego_planner.launch">
    <arg name="platform"         value="$(arg platform)"/>
    <arg name="cloud_topic"      value="$(arg cloud_topic)"/>
    <arg name="planning_horizon" value="3.0"/>
    <arg name="max_vel"          value="$(arg max_vel)"/>
    <arg name="max_acc"          value="$(arg max_acc)"/>
    <arg name="max_jer"          value="$(arg max_jer)"/>
    <arg name="hover_z"          value="$(arg hover_z)"/>
    <arg name="virtual_ceil"     value="$(eval arg('hover_z') + arg('z_band'))"/>
    <arg name="virtual_ground"   value="-1.0"/>
  </include>

  <!-- Waypoint sequencer: /next_goal one at a time, advance on
       /goal_reached, wrap for continuous laps. Pinned to cores 2-5. -->
  <node pkg="ee478_planner" type="waypoint_loop_node.py"
        name="waypoint_loop" output="screen" launch-prefix="taskset -c 2-5">
    <param name="waypoints"     value="$(arg waypoints)"/>
    <param name="z"             value="$(arg hover_z)"/>
    <param name="loop"          value="$(arg loop)"/>
    <param name="start_delay_s" value="14.0"/>
  </node>
</launch>
