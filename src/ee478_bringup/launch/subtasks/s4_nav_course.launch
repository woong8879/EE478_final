<?xml version="1.0"?>
<!--
  Sub-task 4: OBSTACLE-AWARE NAVIGATION
  =====================================
  Drone takes off, EGO-Planner is brought up, ONE /next_goal is
  injected so EGO has to plan around whatever is in the depth cloud.

  SAFETY: real-drone test should use a SHORT goal (e.g. 1-2 m
  forward) for the very first run. Bump goal_x / goal_y once you
  have confidence.

  Sim:
    roslaunch ee478_bringup s4_nav_course.launch platform:=sim \
        goal_x:=15.0 goal_y:=0.0
  Real (first run, conservative):
    roslaunch ee478_bringup s4_nav_course.launch platform:=real \
        goal_x:=2.0 goal_y:=0.0 max_vel:=0.4
-->
<launch>
  <arg name="platform"   default="sim"/>
  <arg name="vio_source" default="gt"/>
  <arg name="hover_z"
       default="$(eval 0.5 if arg('platform') == 'real' else 0.7)"/>
  <arg name="goal_x"     default="15.0"/>
  <arg name="goal_y"     default="0.0"/>
  <arg name="goal_z"
       default="$(eval 0.5 if arg('platform') == 'real' else 0.7)"/>
  <arg name="max_vel"
       default="$(eval 0.4 if arg('platform') == 'real' else 1.0)"/>
  <arg name="fcu_url"
       default="serial:///dev/ttyTHS1:921600"/>

  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="platform"   value="$(arg platform)"/>
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="hover_z"    value="$(arg hover_z)"/>
    <arg name="fcu_url"    value="$(arg fcu_url)"/>
  </include>

  <!-- Cloud topic: sim uses gazebo iris depth camera; on real the
       RealSense driver publishes /camera/depth/color/points by
       default — override cloud_topic if you remap. -->
  <arg name="cloud_topic"
       default="$(eval '/iris_depth_camera_vio/camera/depth/points'
                       if arg('platform') == 'sim'
                       else '/camera/depth/color/points')"/>
  <include file="$(find ee478_planner)/launch/ego_planner.launch">
    <arg name="cloud_topic"      value="$(arg cloud_topic)"/>
    <arg name="planning_horizon" value="3.0"/>
    <arg name="max_vel"          value="$(arg max_vel)"/>
  </include>

  <node pkg="rostopic" type="rostopic" name="goal_injector"
        args="pub -l -r 0.5 /next_goal geometry_msgs/PoseStamped
              '{header: {frame_id: map},
                pose: {position: {x: $(arg goal_x),
                                  y: $(arg goal_y),
                                  z: $(arg goal_z)},
                       orientation: {w: 1.0}}}'"
        launch-prefix="bash -c 'sleep 25; $0 $@'"/>
</launch>
