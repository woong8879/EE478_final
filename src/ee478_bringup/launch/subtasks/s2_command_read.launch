<?xml version="1.0"?>
<!--
  Sub-task 2: COMMAND READ
  ========================
  Just runs command_interpreter on top of an airborne drone. Pure
  software node, identical on sim and real.

  Sim:
    roslaunch ee478_bringup s2_command_read.launch platform:=sim \
        mission_command:="Deliver to the cafe"
  Real:
    roslaunch ee478_bringup s2_command_read.launch platform:=real \
        mission_command:="Deliver to the cafe"

  Verify:
    rostopic echo /mission_target   # expect CAFE / PHARMACY / ...

  You can also test the LLM path by leaving mission_command empty and
  publishing live:
    rostopic pub -1 /mission_command std_msgs/String \
      "data: 'Drop this at the pharmacy please'"

  Real-drone TODO: replace the String input with
  command_screen_reader_node (YOLO + OCR on the camera frame).
-->
<launch>
  <arg name="platform"        default="real"/>
  <arg name="vio_source"      default="gt"/>
  <arg name="hover_z"
       default="$(eval 0.5 if arg('platform') == 'real' else 0.7)"/>
  <arg name="mission_command" default=""/>
  <arg name="fcu_url"
       default="serial:///dev/ttyTHS0:921600"/>

  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="platform"   value="$(arg platform)"/>
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="hover_z"    value="$(arg hover_z)"/>
    <arg name="fcu_url"    value="$(arg fcu_url)"/>
  </include>

  <node pkg="ee478_agent" type="command_interpreter_node.py"
        name="command_interpreter" output="screen">
    <param name="initial_command" value="$(arg mission_command)"/>
    <param name="allow_llm"       value="true"/>
  </node>
</launch>
