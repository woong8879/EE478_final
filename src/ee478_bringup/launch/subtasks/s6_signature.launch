<?xml version="1.0"?>
<!--
  Sub-task 6: SIGNATURE MOVE (yaw spin in place)
  ==============================================
  Drone is hovering at hover_z. We trigger signature_move with a
  fixed store_id (the actual id is just a label for /goal_reached,
  it doesn't change the motion). signature_move publishes the
  in-place yaw-spin waypoints to /next_goal; ego_bridge or
  direct_goal_follower carries them through.

  Test:
    roslaunch ee478_bringup s6_signature.launch
    # in another shell after the drone has finished takeoff:
    rostopic pub -1 /mission/signature_trigger std_msgs/Int32 "data: 7"
    rostopic echo /mission/signature_done
    # expect: data: True  after ~10-20 s of yaw rotation
-->
<launch>
  <arg name="vio_source" default="gt"/>
  <arg name="hover_z"    default="0.7"/>

  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="hover_z"    value="$(arg hover_z)"/>
  </include>

  <!-- direct_goal_follower so the signature waypoints actually drive
       the drone (no EGO needed for an in-place spin). -->
  <node pkg="ee478_planner" type="direct_goal_follower.py"
        name="direct_goal_follower" output="screen">
    <param name="rate_hz"          value="20.0"/>
    <param name="arrival_radius_m" value="0.4"/>
  </node>

  <node pkg="ee478_agent" type="signature_move_node.py"
        name="signature_move" output="screen">
    <param name="spin_dyaw_deg" value="180.0"/>
    <param name="hover_z"       value="$(arg hover_z)"/>
  </node>
</launch>
