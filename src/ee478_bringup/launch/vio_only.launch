<?xml version="1.0"?>
<!--
  Phase 1 verification rig: PX4 SITL + Gazebo + a VIO source + bridge +
  minimal flight (takeoff + hover, no planner, no agent).

  The point is to confirm:
    - PX4 starts + MAVROS connects + drone arms + takes off
    - vio source publishes a pose at ~30 Hz
    - vio_bridge republishes /mavros/vision_pose/pose and PX4 EKF2
      either ignores it (GPS+baro mode) or fuses it (VIO airframe)
    - covariance + jump safety gates work without producing
      teleports

  vio_source: "gt"    -> gt_vision_bridge_node (Gazebo ground-truth, SIM)
              "vins"  -> VINS-Fusion mono+IMU (real-drone target).
                         Currently does NOT initialise reliably in
                         PX4 SITL because mono-VIO scale init needs
                         translation that the settle phase blocks;
                         use 'gt' for sim, 'vins' on the real drone.

  Usage:
    source ~/EE478/final_project_ws/setup_env.sh
    roslaunch ee478_bringup vio_only.launch              # default = gt
    roslaunch ee478_bringup vio_only.launch vio_source:=vins
-->
<launch>
  <arg name="vio_source" default="gt"/>

  <!-- PX4 SITL. Use the VIO airframe so EKF2 fuses vision_pose. -->
  <include file="$(find ee478_bringup)/launch/px4_sitl.launch">
    <arg name="vehicle" value="iris_depth_camera_vio"/>
  </include>

  <!-- Ground-truth VIO surrogate (sim only) -->
  <group if="$(eval vio_source == 'gt')">
    <node pkg="ee478_localization" type="gt_vision_bridge_node.py"
          name="gt_vision_bridge" output="screen">
      <param name="target_model" value="iris_depth_camera_vio"/>
      <param name="rate_hz"      value="30.0"/>
    </node>
  </group>

  <!-- Real VIO: VINS-Fusion mono+IMU + bridge with safety gates -->
  <group if="$(eval vio_source == 'vins')">
    <include file="$(find ee478_localization)/launch/vins_sim.launch"/>
    <node pkg="ee478_localization" type="vio_bridge_node.py"
          name="vio_bridge" output="screen">
      <param name="vo_topic"              value="/vins_estimator/odometry"/>
      <param name="loop_topic"            value="/loop_fusion/odometry_rect"/>
      <param name="landmark_anchor_topic" value="/landmark_anchor_pose"/>
      <param name="vision_pose_topic"     value="/mavros/vision_pose/pose"/>
      <param name="rate_hz"               value="30.0"/>
      <param name="max_cov_m2"            value="1.0"/>
      <param name="max_jump_m"            value="0.5"/>
      <param name="anchor_blend_rate"     value="0.2"/>
    </node>
  </group>

  <!-- Minimal flight: takeoff and hold. -->
  <node pkg="ee478_planner" type="offboard_controller.py"
        name="offboard_controller" output="screen">
    <remap from="~goal"    to="/offboard/goal"/>
    <remap from="~cmd_raw" to="/offboard/cmd_raw"/>
    <param name="takeoff_alt" value="0.7"/>
    <param name="auto_arm"    value="true"/>
    <!-- VIO airframe + good vision_pose => EKF stable immediately -->
    <param name="settle_s"    value="10.0"/>
    <param name="rate_hz"     value="20.0"/>
  </node>
</launch>
