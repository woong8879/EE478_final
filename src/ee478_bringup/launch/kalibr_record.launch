<?xml version="1.0"?>
<!--
  kalibr_record.launch — one-shot Kalibr cam-IMU bag recorder.

  Brings up everything and AUTO-RECORDS to a bag, plus an rqt_image_view so
  you can see the IR image while waving the AprilGrid:
    * RealSense IR stereo, projector OFF (emitter:=0) for a clean grid.
    * MAVROS -> Pixhawk IMU on /mavros/imu/data_raw.
    * rosbag record (auto-starts) -> ~/kalibr_cal/cam_imu.bag
    * rqt_image_view on the left IR (/camera/infra1/image_rect_raw).
  NO VINS (would just diverge on the camera IMU and is not needed here).

  Usage:
    roslaunch ee478_bringup kalibr_record.launch
    # wave the grid through all 6 DoF for ~60-90 s, keeping it in BOTH IR
    # views, then ONE Ctrl+C — rosbag finalizes ~/kalibr_cal/cam_imu.bag.

  Re-record: delete the old bag first (rm ~/kalibr_cal/cam_imu.bag) or pass
    bag:=~/kalibr_cal/cam_imu2.bag
-->
<launch>
  <arg name="fcu_url" default="serial:///dev/ttyTHS0:921600"/>
  <arg name="bag"     default="$(env HOME)/kalibr_cal/cam_imu.bag"/>

  <!-- IR stereo + depth, projector OFF for clean AprilGrid. IR at 15 fps
       (not 30): plenty for Kalibr cam-IMU (cam << IMU rate), and it HALVES
       the bag so rosbag finalizes its index well within roslaunch's ~15 s
       shutdown window (the 30 fps / 2.8 GB bag got SIGKILLed mid-close ->
       unindexed/unrecoverable). Also makes Kalibr run much faster. -->
  <include file="$(find ee478_bringup)/launch/realsense_d435i_vins.launch">
    <arg name="emitter"      value="0"/>
    <arg name="infra_fps"    value="15"/>
    <arg name="enable_color" value="false"/>  <!-- not needed for Kalibr; keep recording lean -->
  </include>

  <!-- MAVROS -> /mavros/imu/data_raw (Pixhawk IMU). -->
  <include file="$(find ee478_bringup)/launch/px4_real.launch">
    <arg name="fcu_url" value="$(arg fcu_url)"/>
  </include>

  <!-- AUTO-RECORD the 3 topics Kalibr needs. Pinned to cores 2-5 so the
       bag writer never competes with the camera nodelet on cores 0,1. -->
  <node pkg="rosbag" type="record" name="kalibr_recorder" output="screen"
        launch-prefix="taskset -c 2-5"
        args="-O $(arg bag)
              /camera/infra1/image_rect_raw
              /camera/infra2/image_rect_raw
              /mavros/imu/data_raw"/>

  <!-- Live IR view so you can frame the grid (left IR camera). -->
  <node pkg="rqt_image_view" type="rqt_image_view" name="ir_view"
        launch-prefix="taskset -c 2-5"
        args="/camera/infra1/image_rect_raw"/>
</launch>
