<?xml version="1.0"?>
<!--
  EE478 FINAL — full autonomous delivery mission (real drone).

  The operator flips OFFBOARD on the RC; the stack then runs end-to-end:
    1. auto-arm, climb to hover_z.
    2. Gate 1/2/3 (each): NAV to the quiz point -> ChatGPT reads the monitor
       and picks the LEFT/RIGHT opening -> cross it (tags verify the centre).
         gate1 wall x=3.5 | tags 281/282 (L) 283/284 (R)
         gate2 wall y=3.5 | tags 266/267 (L) 268/269 (R)
         gate3 wall x=3.5 | tags 271/274 (L) 275/276 (R); a one-shot tag
               anchor (274+275) corrects drift before the landing phase.
    3. precision_land: fly to the box row, find the target box, centre its top
       with the down camera, descend onto it, cut motors on the box.

  RUN
    export OPENAI_API_KEY=sk-...
    roslaunch ee478_bringup final.launch target:=hamburger   # store|pharmacy|hamburger|cafe
-->
<launch>
  <arg name="target"  default="cafe"/>   <!-- store|pharmacy|hamburger|cafe -->
  <arg name="hover_z" default="0.7"/>
  <arg name="fcu_url" default="serial:///dev/ttyTHS0:921600"/>
  <arg name="api_key" default="$(optenv OPENAI_API_KEY)"/>

  <!-- takeoff + RealSense/VIO/MAVROS + dual delivery cameras + AprilTag
       detector + flight recorder -->
  <include file="$(find ee478_bringup)/launch/subtasks/s1_takeoff.launch">
    <arg name="platform" value="real"/>
    <arg name="hover_z"  value="$(arg hover_z)"/>
    <arg name="fcu_url"  value="$(arg fcu_url)"/>
  </include>

  <!-- EGO local planner: obstacle-avoiding trajectories for the gate legs.
       Ceiling = hover_z + 0.8 keeps the 0.8 m MOUNT climb inside the map. -->
  <include file="$(find ee478_planner)/launch/ego_planner.launch">
    <arg name="platform"         value="real"/>
    <arg name="cloud_topic"      value="/camera/depth/points"/>
    <arg name="planning_horizon" value="3.0"/>
    <arg name="max_vel"          value="0.3"/>
    <arg name="max_acc"          value="0.3"/>
    <arg name="max_jer"          value="2.0"/>
    <arg name="hover_z"          value="$(arg hover_z)"/>
    <arg name="virtual_ceil"     value="$(eval arg('hover_z') + 0.8)"/>
    <arg name="virtual_ground"   value="-1.0"/>
  </include>

  <!-- gate orchestrator: NAV + ChatGPT quiz + tag-verified crossing, x3 -->
  <node pkg="ee478_agent" type="final_mission_node.py" name="final_mission"
        output="screen" launch-prefix="taskset -c 2-5">
    <param name="api_key" value="$(arg api_key)"/>
    <param name="target"  value="$(arg target)"/>
    <param name="hover_z" value="$(arg hover_z)"/>
  </node>

  <!-- box search + approach + landing; waits for final_mission's handoff -->
  <node pkg="ee478_agent" type="precision_land_node.py" name="precision_land"
        output="screen" launch-prefix="taskset -c 2-5">
    <param name="auto"         value="false"/>   <!-- external start -->
    <param name="target_label" value="$(arg target)"/>
    <param name="hover_z"      value="$(arg hover_z)"/>
    <rosparam>
      down_cam_back_m: 0.14
      box_height_m: 0.26
      search_max_m: 1.0
    </rosparam>
  </node>
</launch>
