<?xml version="1.0"?>
<!--
  PX4 SITL + Gazebo Classic + MAVROS for the EE478 drone-team world.

  Requires:
    - ros-noetic-mavros, ros-noetic-mavros-extras
    - PX4-Autopilot v1.15.4 at $HOME/PX4-Autopilot, already built
    - install_geographiclib_datasets.sh executed once

  Usage:
    source ~/EE478/final_project_ws/setup_env.sh
    roslaunch ee478_bringup px4_sitl.launch
-->
<launch>
  <!-- vehicle = PX4 airframe + Gazebo model (same name).
       For PX4 EKF2 vision-fusion mode we use a custom airframe (with
       EKF2_EV_CTRL/HGT_REF/GPS_CTRL overrides) that re-uses the base
       iris_depth_camera Gazebo SDF — pass that explicitly. -->
  <arg name="vehicle"        default="iris_depth_camera"/>
  <arg name="sdf"            default=""/>
  <arg name="world"
       default="$(find drone_worlds)/worlds/ee478_project_simple.world"/>
  <arg name="fcu_url"        default="udp://:14540@127.0.0.1:14557"/>
  <arg name="gcs_url"        default=""/>
  <arg name="tgt_system"     default="1"/>
  <arg name="tgt_component"  default="1"/>
  <arg name="px4_autopilot"  default="$(env HOME)/PX4-Autopilot"/>

  <!-- Spawn near the world origin. z = rotor height keeps PX4 EKF2
       from seeing a few seconds of free-fall and drifting the z
       estimate to ~-2 m. -->
  <arg name="x"  default="0.0"/>
  <arg name="y"  default="0.0"/>
  <arg name="z"  default="0.10"/>
  <arg name="Y"  default="0.0"/>

  <!-- If sdf arg is empty, default to the iris_depth_camera SDF
       (so custom VIO airframes can re-use the base depth-camera). -->
  <arg name="effective_sdf"
       value="$(arg sdf)"
       if="$(eval sdf != '')"/>
  <arg name="effective_sdf"
       value="$(arg px4_autopilot)/Tools/simulation/gazebo-classic/sitl_gazebo-classic/models/iris_depth_camera/iris_depth_camera.sdf"
       unless="$(eval sdf != '')"/>

  <include file="$(eval px4_autopilot + '/launch/posix_sitl.launch')">
    <arg name="vehicle" value="$(arg vehicle)"/>
    <arg name="sdf"     value="$(arg effective_sdf)"/>
    <arg name="world"   value="$(arg world)"/>
    <arg name="x"       value="$(arg x)"/>
    <arg name="y"       value="$(arg y)"/>
    <arg name="z"       value="$(arg z)"/>
    <arg name="Y"       value="$(arg Y)"/>
  </include>

  <include file="$(find mavros)/launch/px4.launch">
    <arg name="fcu_url"       value="$(arg fcu_url)"/>
    <arg name="gcs_url"       value="$(arg gcs_url)"/>
    <arg name="tgt_system"    value="$(arg tgt_system)"/>
    <arg name="tgt_component" value="$(arg tgt_component)"/>
  </include>

  <!-- One-shot PX4 parameter tuning (MPC_XY_VEL_MAX caps etc.). -->
  <node name="px4_param_setter" pkg="ee478_bringup"
        type="px4_param_setter.py" output="screen" required="false"/>

  <!-- Static base_link -> camera_link TF.
       The libgazebo_ros_openni_kinect plugin publishes images with
       header.frame_id = "camera_link"; the pixel convention is
       optical (x-right, y-down, z-forward), so this static TF
       carries the body->optical rotation as well as the 10 cm
       forward / 5 cm up mounting offset on the iris frame. -->
  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_to_camera_link"
        args="0.1 0 0.05 -1.5707963 0 -1.5707963 base_link camera_link"/>
</launch>
