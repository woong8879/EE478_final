<?xml version="1.0"?>
<!--
  Full EE478 final-project mission stack.

  Brings up:
    - PX4 SITL + Gazebo + MAVROS + camera TF
    - GT or VINS-Fusion VIO (sim default = gt)
    - direct_goal_follower OR ego_planner (sim default = direct)
    - sim_world_publisher (sim only: fabricates /semantic_map and
                          /quiz/gates from gazebo GT)
    - command_interpreter (LLM/keyword) -> /mission_target
    - quiz_solver         (math eval)   -> /quiz/chosen_pose
    - signature_move      (bobble+spin)
    - mission_fsm         (5-step orchestrator)

  Args:
    vio_source = gt | vins
    planner    = direct | ego
    mission_command = "Deliver to the cafe"     // natural language
    question   = "5 + 9 = ?"
    gate_left_label / gate_center_label / gate_right_label = ints
-->
<launch>
  <arg name="vio_source"      default="gt"/>
  <arg name="planner"         default="direct"/>
  <arg name="mission_command" default="Deliver to the cafe"/>
  <arg name="question"        default="5 + 9 = ?"/>
  <arg name="gate_left_label"   default="14"/>
  <arg name="gate_center_label" default="7"/>
  <arg name="gate_right_label"  default="9"/>

  <!-- 1. core sim + VIO + planner (Phase 1-3 stack). -->
  <include file="$(find ee478_bringup)/launch/flight_test.launch">
    <arg name="vio_source" value="$(arg vio_source)"/>
    <arg name="planner"    value="$(arg planner)"/>
  </include>

  <!-- 2. SIM perception stub (Phase 5+ trigger source). -->
  <node pkg="ee478_perception" type="sim_world_publisher_node.py"
        name="sim_world_publisher" output="screen">
    <param name="question"           value="$(arg question)"/>
    <param name="gate_left_label"    value="$(arg gate_left_label)"/>
    <param name="gate_center_label"  value="$(arg gate_center_label)"/>
    <param name="gate_right_label"   value="$(arg gate_right_label)"/>
  </node>

  <!-- 3. Landmark anchor publisher (Phase 4). Only meaningful when
       VINS is in use; harmless in GT mode (no SignboardArray ->
       silent). -->
  <node pkg="ee478_localization"
        type="landmark_anchor_publisher_node.py"
        name="landmark_anchor_publisher" output="screen"/>

  <!-- 3b. tf broadcaster map -> base_link from /mavros/local_position
       /pose so the world_cloud_publisher inside ego_planner.launch
       can transform depth clouds from camera_link to map. -->
  <node pkg="ee478_localization"
        type="odom_tf_broadcaster_node.py"
        name="odom_tf_broadcaster" output="screen"/>

  <!-- 3c. VINS-Fusion pre-flight excitation (only when VINS is the
       VIO source). After takeoff, this node injects a 5 s lissajous
       on /next_goal so VINS gets 3-axis motion data and converges
       on metric scale BEFORE the mission proper starts. The FSM
       waits for /vins_excitation/done before leaving the takeoff
       hover. -->
  <group if="$(eval vio_source == 'vins')">
    <node pkg="ee478_localization" type="vins_excitation_node.py"
          name="vins_excitation" output="screen">
      <param name="excitation_duration_s" value="5.0"/>
      <param name="amplitude_xy_m"         value="0.3"/>
      <param name="amplitude_z_m"          value="0.15"/>
      <param name="center_z_m"             value="0.7"/>
    </node>
    <!-- SIM-ONLY landmark anchor injection at 1 Hz. Stands in for
         the real-drone perception pipeline. Without this, VINS drift
         accumulates unchecked and the drone navigates by stale
         vision_pose. -->
    <node pkg="ee478_localization" type="sim_landmark_anchor_node.py"
          name="sim_landmark_anchor" output="screen">
      <param name="rate_hz" value="1.0"/>
    </node>
  </group>

  <!-- 4. Mission agents (Phase 5 / 6 / 8 / 10). -->
  <node pkg="ee478_agent" type="command_interpreter_node.py"
        name="command_interpreter" output="screen">
    <param name="initial_command" value="$(arg mission_command)"/>
    <param name="allow_llm"       value="true"/>
  </node>

  <node pkg="ee478_agent" type="quiz_solver_node.py"
        name="quiz_solver" output="screen">
    <param name="target_z" value="0.7"/>
  </node>

  <node pkg="ee478_agent" type="signature_move_node.py"
        name="signature_move" output="screen">
    <param name="bobble_dz"     value="0.4"/>
    <param name="spin_dyaw_deg" value="180.0"/>
  </node>

  <node pkg="ee478_agent" type="mission_fsm_node.py"
        name="mission_fsm" output="screen">
    <param name="quiz_approach_back_m" value="2.0"/>
    <param name="gate_pass_forward_m"  value="1.5"/>
    <param name="store_standoff_m"     value="3.0"/>
    <!-- direct planner has no obstacle avoidance -> we hand-route
         around the corridor walls. EGO does its own avoidance so
         we should pass only the final goals through. -->
    <param name="use_bypass" value="$(eval planner == 'direct')"/>
    <!-- Wait for VINS excitation to finish only when VINS is the
         VIO source (GT bridge doesn't need excitation). -->
    <param name="wait_for_vins_excite"
           value="$(eval vio_source == 'vins')"/>
  </node>
</launch>
