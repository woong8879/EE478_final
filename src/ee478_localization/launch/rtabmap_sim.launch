<?xml version="1.0"?>
<!--
  RGBD VIO via RTAB-Map's rgbd_odometry node. Replaces VINS-Fusion as
  the EE478 final-project VIO source. RGBD recovers metric scale from
  the depth image directly (no mono+IMU scale init), which means:

    1. Works on a STATIC drone at startup (no pre-flight excitation
       motion required).
    2. Works in SITL exactly the same way it works on the real
       drone — no GT-bootstrap shim anywhere in the localisation
       path, so flashing the same code to the Jetson does not
       silently break the moment /gazebo/model_states disappears.

  Subscribes (same topic names on sim + real if the RealSense D435i
  driver is configured to publish under iris_depth_camera_vio/...):
    /iris_depth_camera_vio/camera/rgb/image_raw      (sensor_msgs/Image)
    /iris_depth_camera_vio/camera/depth/image_raw    (sensor_msgs/Image)
    /iris_depth_camera_vio/camera/rgb/camera_info    (sensor_msgs/CameraInfo)
    /mavros/imu/data                                 (sensor_msgs/Imu)

  Publishes:
    /rtabmap/odom    (nav_msgs/Odometry) — what vio_bridge consumes
                                            and forwards to MAVROS as
                                            /mavros/vision_pose/pose.
-->
<launch>
  <arg name="rgb_topic"
       default="/iris_depth_camera_vio/camera/rgb/image_raw"/>
  <arg name="depth_topic"
       default="/iris_depth_camera_vio/camera/depth/image_raw"/>
  <arg name="camera_info_topic"
       default="/iris_depth_camera_vio/camera/rgb/camera_info"/>
  <arg name="imu_topic" default="/mavros/imu/data"/>

  <!-- RGBD visual-inertial odometry. F2M (frame-to-map) odometry
       uses tracked features, IMU gives short-term motion priors.
       publish_tf=false: TF is handled by odom_tf_broadcaster_node
       (driven by mavros/local_position/pose).
  -->
  <node pkg="rtabmap_odom" type="rgbd_odometry" name="rtabmap_odom"
        output="screen">
    <remap from="rgb/image"       to="$(arg rgb_topic)"/>
    <remap from="depth/image"     to="$(arg depth_topic)"/>
    <remap from="rgb/camera_info" to="$(arg camera_info_topic)"/>
    <remap from="imu"             to="$(arg imu_topic)"/>
    <remap from="odom"            to="/rtabmap/odom"/>

    <param name="frame_id"          value="base_link"/>
    <param name="odom_frame_id"     value="odom"/>
    <param name="publish_tf"        value="false"/>
    <param name="approx_sync"       value="true"/>
    <param name="approx_sync_max_interval" value="0.04"/>
    <param name="queue_size"        value="20"/>
    <param name="wait_imu_to_init"  value="true"/>
    <param name="guess_frame_id"    value=""/>

    <!-- Odometry quality tuning. F2M is much more robust than F2F
         in low-texture corridors than the EE478 drone_worlds map. -->
    <param name="Odom/Strategy"        value="0"/>
    <param name="OdomF2M/MaxSize"       value="2000"/>
    <param name="Vis/MinInliers"       value="12"/>
    <param name="Vis/MaxFeatures"      value="800"/>
    <param name="Reg/Strategy"         value="0"/>
    <param name="Vis/EstimationType"   value="1"/>
  </node>
</launch>
